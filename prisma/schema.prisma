// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id          Int       @id @default(autoincrement())
  email       String    @unique(map: "User_email_key")
  name        String
  password    String
  avatar      String?
  gender      String?
  phoneNumber String?   @unique(map: "User_phoneNumber_key")
  address     String?
  birthDate   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now())
  notebooks Notebook[]
}

model Word {
  id         Int           @id @default(autoincrement())
  word       String        @unique @db.VarChar(255)
  pronounce  String?       @db.VarChar(255)
  synonyms   Synonym[]
  antonyms   Antonym[]
  contents   ContentWord[]
  @@map("words")
}

model Synonym {
  id       Int    @id @default(autoincrement())
  synonym  String @db.VarChar(255)
  word_id  Int
  word     Word   @relation(fields: [word_id], references: [id], onDelete: Cascade)
  @@map("synonyms")
}

model Antonym {
  id       Int    @id @default(autoincrement())
  antonym  String @db.VarChar(255)
  word_id  Int
  word     Word   @relation(fields: [word_id], references: [id], onDelete: Cascade)
  @@map("antonyms")
}

model ContentWord {
  id               Int           @id @default(autoincrement())
  kind             String        @db.VarChar(100)
  word_id          Int
  word             Word          @relation(fields: [word_id], references: [id], onDelete: Cascade)
  kind_content_id  Int
  kindContents     KindContent[]
  idioms           Idiom[]
  @@map("content_words")
}

model KindContent {
  id               Int        @id @default(autoincrement())
  means            String     @db.Text
  content_word_id  Int
  contentWord      ContentWord @relation(fields: [content_word_id], references: [id], onDelete: Cascade)
  examples         Example[]
  @@map("kind_contents")
}

model Example {
  id               Int         @id @default(autoincrement())
  example          String      @db.Text
  mean             String      @db.Text
  kind_content_id  Int
  kindContent      KindContent @relation(fields: [kind_content_id], references: [id], onDelete: Cascade)
  @@map("examples")
}

model Idiom {
  id               Int          @id @default(autoincrement())
  idiom            String       @db.Text
  mean             String       @db.Text
  content_word_id  Int
  contentWord      ContentWord  @relation(fields: [content_word_id], references: [id], onDelete: Cascade)
  @@map("idioms")
}

model Notebook {
  id        Int            @id @default(autoincrement())
  userId    Int            @map("user_id")
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String         @db.VarChar(255)
  total     Int            @default(0)
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")
  notebookWords NotebookWord[]
  @@map("notebooks")
}

model NotebookWord {
  id         Int       @id @default(autoincrement())
  notebookId Int       @map("notebook_id")
  notebook   Notebook  @relation(fields: [notebookId], references: [id], onDelete: Cascade)
  word       String    @db.VarChar(255)
  pronounce  String?   @db.VarChar(255)
  kind       String?   @db.VarChar(255)
  mean       String?
  note       String?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  @@map("notebook_words")
}